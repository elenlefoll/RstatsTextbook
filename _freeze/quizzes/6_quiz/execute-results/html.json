    "markdown": "# Ch. 6: Tasks & Quizzes {.unnumbered}\n\n::: {.callout-tip collapse=\"false\"}\n#### Your turn! {.unnumbered}\n\n[**Q6.1**]{style=\"color:green;\"} What types of data were collected as part of @DabrowskaExperienceAptitudeIndividual2019?\n\n\n::: {.cell}\n::: {.cell-output-display}\n\n```{=html}\n<form name=\"form_Q6_1\" onsubmit=\"return validate_form_Q6_1()\" method=\"post\">\n<label>\n<input type=\"checkbox\" id=\"answer_Q6_1_1\" value=\"Participants&#39; results on a vocabulary test\"/>\nParticipants' results on a vocabulary test\n</label>\n<br/>\n<label>\n<input type=\"checkbox\" id=\"answer_Q6_1_2\" value=\"Participants&#39; results on a collocations test\"/>\nParticipants' results on a collocations test\n</label>\n<br/>\n<label>\n<input type=\"checkbox\" id=\"answer_Q6_1_3\" value=\"Participants&#39; results on a nonverbal intelligence test\"/>\nParticipants' results on a nonverbal intelligence test\n</label>\n<br/>\n<label>\n<input type=\"checkbox\" id=\"answer_Q6_1_4\" value=\"Participants&#39; results on a grammar test\"/>\nParticipants' results on a grammar test\n</label>\n<br/>\n<label>\n<input type=\"checkbox\" id=\"answer_Q6_1_5\" value=\"Sociodemographic information about the participants including their age and level of education\"/>\nSociodemographic information about the participants including their age and level of education\n</label>\n<br/>\n<label>\n<input type=\"checkbox\" id=\"answer_Q6_1_6\" value=\"Participants&#39; results on a language analytic ability test\"/>\nParticipants' results on a language analytic ability test\n</label>\n<br/>\n<input type=\"submit\" value=\"Check answer\"/>\n<div id=\"result_Q6_1\"></div>\n</form>\n<script>function validate_form_Q6_1() {var text; var x1 = document.getElementById('answer_Q6_1_1'); var x2 = document.getElementById('answer_Q6_1_2'); var x3 = document.getElementById('answer_Q6_1_3'); var x4 = document.getElementById('answer_Q6_1_4'); var x5 = document.getElementById('answer_Q6_1_5'); var x6 = document.getElementById('answer_Q6_1_6'); if (x1.checked == true&x2.checked == true&x3.checked == true&x4.checked == true&x5.checked == true&x6.checked == true){text = 'Well done!';} else {text = 'That’s a good start, but there are more…';} document.getElementById('result_Q6_1').innerHTML = text; evaluate_final_score(); return false;}function evaluate_final_score(){\n         element = document.getElementById('checkdown_final_score');\n         if(element === null){return false;} else {var element, text, res1;res1 = document.getElementById('result_Q6_1').innerText == 'Well done!';text = res1;element.innerHTML = text;\n         return false;\n         }}</script>\n```\n\n:::\n:::\n\n\n[**Q6.2**]{style=\"color:green;\"} On average, how did the English L2 speakers perform compared to the native speakers in @DabrowskaExperienceAptitudeIndividual2019?\n\n\n::: {.cell}\n::: {.cell-output-display}\n\n```{=html}\n<form name=\"form_Q6_2\" onsubmit=\"return validate_form_Q6_2()\" method=\"post\">\n<label>\n<input type=\"radio\" name=\"answer_Q6_2\" id=\"answer_Q6_2_1\" value=\"On average, L2 speakers performed better on grammar tasks than native speakers\"/>\nOn average, L2 speakers performed better on grammar tasks than native speakers\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q6_2\" id=\"answer_Q6_2_2\" value=\"On average, both groups performed equally well on grammar and vocabulary tasks.\"/>\nOn average, both groups performed equally well on grammar and vocabulary tasks.\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q6_2\" id=\"answer_Q6_2_3\" value=\"The observed differences in performance between native speakers and L2 speakers were not statistically significant.\"/>\nThe observed differences in performance between native speakers and L2 speakers were not statistically significant.\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q6_2\" id=\"answer_Q6_2_4\" value=\"On average, native speakers outperformed L2 speakers on all language tasks, with the most significant difference observed in collocation tasks.\"/>\nOn average, native speakers outperformed L2 speakers on all language tasks, with the most significant difference observed in collocation tasks.\n</label>\n<br/>\n<input type=\"submit\" value=\"Check answer\"/>\n<div id=\"result_Q6_2\"></div>\n</form>\n<script>function validate_form_Q6_2() {var x, text; var x = document.forms['form_Q6_2']['answer_Q6_2'].value;if (x == 'On average, native speakers outperformed L2 speakers on all language tasks, with the most significant difference observed in collocation tasks.'){text = 'That’s right.';} else {text = 'No, read the abstract again.';} document.getElementById('result_Q6_2').innerHTML = text; evaluate_final_score(); return false;}function evaluate_final_score(){\n         element = document.getElementById('checkdown_final_score');\n         if(element === null){return false;} else {var element, text, res1, res2;res1 = document.getElementById('result_Q6_1').innerText == 'Well done!'; res2 = document.getElementById('result_Q6_2').innerText == 'That’s right.';text = res1 + res2;element.innerHTML = text;\n         return false;\n         }}</script>\n```\n\n:::\n:::\n\n\n[**Q6.3**]{style=\"color:green;\"} Did all native speakers perform better than the L2 speakers in the English vocabulary and grammar tests?\n\n\n::: {.cell}\n::: {.cell-output-display}\n\n```{=html}\n<form name=\"form_Q6_3\" onsubmit=\"return validate_form_Q6_3()\" method=\"post\">\n<label>\n<input type=\"radio\" name=\"answer_Q6_3\" id=\"answer_Q6_3_1\" value=\"This study only looked at average trends, so no conclusive statement can be made about individual participants.\"/>\nThis study only looked at average trends, so no conclusive statement can be made about individual participants.\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q6_3\" id=\"answer_Q6_3_2\" value=\"Yes, the L1 speakers clearly outperformed the L2 speakers in both grammar and vocabulary.\"/>\nYes, the L1 speakers clearly outperformed the L2 speakers in both grammar and vocabulary.\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q6_3\" id=\"answer_Q6_3_3\" value=\"No, while L1 speakers generally performed better, some L2 speakers demonstrated equally high proficiency in grammar and vocabulary.\"/>\nNo, while L1 speakers generally performed better, some L2 speakers demonstrated equally high proficiency in grammar and vocabulary.\n</label>\n<br/>\n<input type=\"submit\" value=\"Check answer\"/>\n<div id=\"result_Q6_3\"></div>\n</form>\n<script>function validate_form_Q6_3() {var x, text; var x = document.forms['form_Q6_3']['answer_Q6_3'].value;if (x == 'No, while L1 speakers generally performed better, some L2 speakers demonstrated equally high proficiency in grammar and vocabulary.'){text = 'That’s right.';} else {text = 'No, read the abstract again.';} document.getElementById('result_Q6_3').innerHTML = text; evaluate_final_score(); return false;}function evaluate_final_score(){\n         element = document.getElementById('checkdown_final_score');\n         if(element === null){return false;} else {var element, text, res1, res2, res3;res1 = document.getElementById('result_Q6_1').innerText == 'Well done!'; res2 = document.getElementById('result_Q6_2').innerText == 'That’s right.'; res3 = document.getElementById('result_Q6_3').innerText == 'That’s right.';text = res1 + res2 + res3;element.innerHTML = text;\n         return false;\n         }}</script>\n```\n\n:::\n:::\n\n:::\n::: {.callout-tip collapse=\"false\"}\n#### Your turn! {.unnumbered}\n\n[**Q6.4**]{style=\"color:green;\"} On which repository/repositories can the data be found?\n\n\n::: {.cell}\n::: {.cell-output-display}\n\n```{=html}\n<form name=\"form_Q6_4\" onsubmit=\"return validate_form_Q6_4()\" method=\"post\">\n<label>\n<input type=\"radio\" name=\"answer_Q6_4\" id=\"answer_Q6_4_1\" value=\"Zenodo\"/>\nZenodo\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q6_4\" id=\"answer_Q6_4_2\" value=\"database.org\"/>\ndatabase.org\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q6_4\" id=\"answer_Q6_4_3\" value=\"IRIS\"/>\nIRIS\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q6_4\" id=\"answer_Q6_4_4\" value=\"ResearchGate\"/>\nResearchGate\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q6_4\" id=\"answer_Q6_4_5\" value=\"All of the above.\"/>\nAll of the above.\n</label>\n<br/>\n<input type=\"submit\" value=\"Check answer\"/>\n<div id=\"result_Q6_4\"></div>\n</form>\n<script>function validate_form_Q6_4() {var x, text; var x = document.forms['form_Q6_4']['answer_Q6_4'].value;if (x == 'IRIS'){text = 'That’s right!';} else {text = 'Are you sure?';} document.getElementById('result_Q6_4').innerHTML = text; evaluate_final_score(); return false;}function evaluate_final_score(){\n         element = document.getElementById('checkdown_final_score');\n         if(element === null){return false;} else {var element, text, res1, res2, res3, res4;res1 = document.getElementById('result_Q6_1').innerText == 'Well done!'; res2 = document.getElementById('result_Q6_2').innerText == 'That’s right.'; res3 = document.getElementById('result_Q6_3').innerText == 'That’s right.'; res4 = document.getElementById('result_Q6_4').innerText == 'That’s right!';text = res1 + res2 + res3 + res4;element.innerHTML = text;\n         return false;\n         }}</script>\n```\n\n:::\n\n::: {.cell-output-display}\n\n```{=html}\n<div id=\"hint_36969\" onclick=\"return show_hint_36969()\">🐭 Click on the mouse for a hint.</div>\n<div id=\"result_36969\" onclick=\"return show_hint_36969()\"></div>\n<script>function show_hint_36969(){var x = document.getElementById('result_36969').innerHTML; if(!x){document.getElementById('result_36969').innerHTML = 'Check the links listed in Appendix S4.';} else {document.getElementById('result_36969').innerHTML = '';}}</script>\n```\n\n:::\n:::\n\n:::\n::: {.callout-tip collapse=\"false\"}\n#### Your turn! {.unnumbered}\n\n[**Q6.5**]{style=\"color:green;\"} In which data format are these two files saved?\n\n\n::: {.cell}\n::: {.cell-output-display}\n\n```{=html}\n<form name=\"form_Q6_5\" onsubmit=\"return validate_form_Q6_5()\" method=\"post\">\n<label>\n<input type=\"radio\" name=\"answer_Q6_5\" id=\"answer_Q6_5_1\" value=\"They are both .txt files.\"/>\nThey are both .txt files.\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q6_5\" id=\"answer_Q6_5_2\" value=\"They are both .xslx files.\"/>\nThey are both .xslx files.\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q6_5\" id=\"answer_Q6_5_3\" value=\"They are both .html files.\"/>\nThey are both .html files.\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q6_5\" id=\"answer_Q6_5_4\" value=\"They are both .csv files.\"/>\nThey are both .csv files.\n</label>\n<br/>\n<input type=\"submit\" value=\"Check answer\"/>\n<div id=\"result_Q6_5\"></div>\n</form>\n<script>function validate_form_Q6_5() {var x, text; var x = document.forms['form_Q6_5']['answer_Q6_5'].value;if (x == 'They are both .csv files.'){text = 'That’s right! 🎉';} else {text = 'Are you sure? 🤨';} document.getElementById('result_Q6_5').innerHTML = text; evaluate_final_score(); return false;}function evaluate_final_score(){\n         element = document.getElementById('checkdown_final_score');\n         if(element === null){return false;} else {var element, text, res1, res2, res3, res4, res5;res1 = document.getElementById('result_Q6_1').innerText == 'Well done!'; res2 = document.getElementById('result_Q6_2').innerText == 'That’s right.'; res3 = document.getElementById('result_Q6_3').innerText == 'That’s right.'; res4 = document.getElementById('result_Q6_4').innerText == 'That’s right!'; res5 = document.getElementById('result_Q6_5').innerText == 'That’s right! 🎉';text = res1 + res2 + res3 + res4 + res5;element.innerHTML = text;\n         return false;\n         }}</script>\n```\n\n:::\n:::\n\n:::\n::: {.callout-tip collapse=\"false\"}\n#### Your turn! {.unnumbered}\n\n[**Q6.6**]{style=\"color:green;\"} Which character is used to separate the values in the file `L1_data.csv`?\n\n\n::: {.cell}\n::: {.cell-output-display}\n\n```{=html}\n<form name=\"form_Q6_6\" onsubmit=\"return validate_form_Q6_6()\" method=\"post\">\n<label>\n<input type=\"radio\" name=\"answer_Q6_6\" id=\"answer_Q6_6_1\" value=\"tab\"/>\ntab\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q6_6\" id=\"answer_Q6_6_2\" value=\"double quotation mark\"/>\ndouble quotation mark\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q6_6\" id=\"answer_Q6_6_3\" value=\"space\"/>\nspace\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q6_6\" id=\"answer_Q6_6_4\" value=\"colon\"/>\ncolon\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q6_6\" id=\"answer_Q6_6_5\" value=\"comma\"/>\ncomma\n</label>\n<br/>\n<input type=\"submit\" value=\"Check answer\"/>\n<div id=\"result_Q6_6\"></div>\n</form>\n<script>function validate_form_Q6_6() {var x, text; var x = document.forms['form_Q6_6']['answer_Q6_6'].value;if (x == 'comma'){text = 'That’s right!';} else {text = 'Are you sure?';} document.getElementById('result_Q6_6').innerHTML = text; evaluate_final_score(); return false;}function evaluate_final_score(){\n         element = document.getElementById('checkdown_final_score');\n         if(element === null){return false;} else {var element, text, res1, res2, res3, res4, res5, res6;res1 = document.getElementById('result_Q6_1').innerText == 'Well done!'; res2 = document.getElementById('result_Q6_2').innerText == 'That’s right.'; res3 = document.getElementById('result_Q6_3').innerText == 'That’s right.'; res4 = document.getElementById('result_Q6_4').innerText == 'That’s right!'; res5 = document.getElementById('result_Q6_5').innerText == 'That’s right! 🎉'; res6 = document.getElementById('result_Q6_6').innerText == 'That’s right!';text = res1 + res2 + res3 + res4 + res5 + res6;element.innerHTML = text;\n         return false;\n         }}</script>\n```\n\n:::\n:::\n\n\n[**Q6.7**]{style=\"color:green;\"} Which character is used to delineate the values?\n\n\n::: {.cell}\n::: {.cell-output-display}\n\n```{=html}\n<form name=\"form_Q6_7\" onsubmit=\"return validate_form_Q6_7()\" method=\"post\">\n<label>\n<input type=\"radio\" name=\"answer_Q6_7\" id=\"answer_Q6_7_1\" value=\"space\"/>\nspace\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q6_7\" id=\"answer_Q6_7_2\" value=\"none\"/>\nnone\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q6_7\" id=\"answer_Q6_7_3\" value=\"dot\"/>\ndot\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q6_7\" id=\"answer_Q6_7_4\" value=\"single quotation mark\"/>\nsingle quotation mark\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q6_7\" id=\"answer_Q6_7_5\" value=\"double quotation mark\"/>\ndouble quotation mark\n</label>\n<br/>\n<input type=\"submit\" value=\"Check answer\"/>\n<div id=\"result_Q6_7\"></div>\n</form>\n<script>function validate_form_Q6_7() {var x, text; var x = document.forms['form_Q6_7']['answer_Q6_7'].value;if (x == 'none'){text = 'You are right: this DSV file does not have a delimiter character. This would be problematic if some of the values included commas but, as they don’t, it’s not a problem.';} else {text = 'No, take a closer look at the extract of the DSV file printed above.';} document.getElementById('result_Q6_7').innerHTML = text; evaluate_final_score(); return false;}function evaluate_final_score(){\n         element = document.getElementById('checkdown_final_score');\n         if(element === null){return false;} else {var element, text, res1, res2, res3, res4, res5, res6, res7;res1 = document.getElementById('result_Q6_1').innerText == 'Well done!'; res2 = document.getElementById('result_Q6_2').innerText == 'That’s right.'; res3 = document.getElementById('result_Q6_3').innerText == 'That’s right.'; res4 = document.getElementById('result_Q6_4').innerText == 'That’s right!'; res5 = document.getElementById('result_Q6_5').innerText == 'That’s right! 🎉'; res6 = document.getElementById('result_Q6_6').innerText == 'That’s right!'; res7 = document.getElementById('result_Q6_7').innerText == 'You are right: this DSV file does not have a delimiter character. This would be problematic if some of the values included commas but, as they don’t, it’s not a problem.';text = res1 + res2 + res3 + res4 + res5 + res6 + res7;element.innerHTML = text;\n         return false;\n         }}</script>\n```\n\n:::\n:::\n\n:::\n::: {.callout-tip collapse=\"false\"}\n#### Your turn! {.unnumbered}\n\nImport both data files from @DabrowskaExperienceAptitudeIndividual2019 using the `read.csv` function as described above. Save the first as the `R` object `L1.data` (as in the example above) and the second as `L2.data`. Then, answer the following questions.\n\n[**Q6.8**]{style=\"color:green;\"} In the two data files from @DabrowskaExperienceAptitudeIndividual2019, each row corresponds to one participant. How many L1 participants were included in this study?\n\n\n::: {.cell}\n::: {.cell-output-display}\n\n```{=html}\n<form name=\"form_Q6_8\" onsubmit=\"return validate_form_Q6_8()\" method=\"post\">\n<label>\n<input type=\"radio\" name=\"answer_Q6_8\" id=\"answer_Q6_8_1\" value=\"2790\"/>\n2790\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q6_8\" id=\"answer_Q6_8_2\" value=\"31\"/>\n31\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q6_8\" id=\"answer_Q6_8_3\" value=\"90\"/>\n90\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q6_8\" id=\"answer_Q6_8_4\" value=\"17\"/>\n17\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q6_8\" id=\"answer_Q6_8_5\" value=\"221\"/>\n221\n</label>\n<br/>\n<input type=\"submit\" value=\"Check answer\"/>\n<div id=\"result_Q6_8\"></div>\n</form>\n<script>function validate_form_Q6_8() {var x, text; var x = document.forms['form_Q6_8']['answer_Q6_8'].value;if (x == '90'){text = 'That’s right!';} else {text = 'Hummm, are you sure?';} document.getElementById('result_Q6_8').innerHTML = text; evaluate_final_score(); return false;}function evaluate_final_score(){\n         element = document.getElementById('checkdown_final_score');\n         if(element === null){return false;} else {var element, text, res1, res2, res3, res4, res5, res6, res7, res8;res1 = document.getElementById('result_Q6_1').innerText == 'Well done!'; res2 = document.getElementById('result_Q6_2').innerText == 'That’s right.'; res3 = document.getElementById('result_Q6_3').innerText == 'That’s right.'; res4 = document.getElementById('result_Q6_4').innerText == 'That’s right!'; res5 = document.getElementById('result_Q6_5').innerText == 'That’s right! 🎉'; res6 = document.getElementById('result_Q6_6').innerText == 'That’s right!'; res7 = document.getElementById('result_Q6_7').innerText == 'You are right: this DSV file does not have a delimiter character. This would be problematic if some of the values included commas but, as they don’t, it’s not a problem.'; res8 = document.getElementById('result_Q6_8').innerText == 'That’s right!';text = res1 + res2 + res3 + res4 + res5 + res6 + res7 + res8;element.innerHTML = text;\n         return false;\n         }}</script>\n```\n\n:::\n\n::: {.cell-output-display}\n\n```{=html}\n<div id=\"hint_48762\" onclick=\"return show_hint_48762()\">🐭 Click on the mouse for a hint.</div>\n<div id=\"result_48762\" onclick=\"return show_hint_48762()\"></div>\n<script>function show_hint_48762(){var x = document.getElementById('result_48762').innerHTML; if(!x){document.getElementById('result_48762').innerHTML = 'Use the command <code>View(L1.data)</code> to display the full dataset in a new tab.';} else {document.getElementById('result_48762').innerHTML = '';}}</script>\n```\n\n:::\n:::\n\n\n[**Q6.9**]{style=\"color:green;\"} How many L2 participants were included in @DabrowskaExperienceAptitu