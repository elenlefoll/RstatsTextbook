    "engine": "knitr",
    "markdown": "# Ch. 5: Tasks & Quizzes {.unnumbered}\n\n::: {.callout-tip collapse=\"false\"}\n#### Your turn! {.unnumbered}\n\n[**Q5.1**]{style=\"color:green;\"} What happens if you type a word without quotation marks in the Console and then press \"enter\"?\n\n\n::: {.cell}\n::: {.cell-output-display}\n\n```{=html}\n<form name=\"form_Q5_1\" onsubmit=\"return validate_form_Q5_1()\" method=\"post\">\n<label>\n<input type=\"radio\" name=\"answer_Q5_1\" id=\"answer_Q5_1_1\" value=\"R automatically wraps the word in quotation marks and processes it as a string.\"/>\nR automatically wraps the word in quotation marks and processes it as a string.\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q5_1\" id=\"answer_Q5_1_2\" value=\"R returns an error message indicating that it expected a number.\"/>\nR returns an error message indicating that it expected a number.\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q5_1\" id=\"answer_Q5_1_3\" value=\"R returns an error message because it interprets the word as an object name or command.\"/>\nR returns an error message because it interprets the word as an object name or command.\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q5_1\" id=\"answer_Q5_1_4\" value=\"R returns an error suggesting that you probably mistyped the word.\"/>\nR returns an error suggesting that you probably mistyped the word.\n</label>\n<br/>\n<input type=\"submit\" value=\"Check answer\"/>\n<div id=\"result_Q5_1\"></div>\n</form>\n<script>function validate_form_Q5_1() {var x, text; var x = document.forms['form_Q5_1']['answer_Q5_1'].value;if (x == 'R returns an error message because it interprets the word as an object name or command.'){text = 'That’s right. Without quotation marks, a string of characters is interpreted by <code>R</code> as the name of an object or function.';} else {text = 'No, this is not what happens. Have you tried it in your Console? What does the error message say?';} document.getElementById('result_Q5_1').innerHTML = text; evaluate_final_score(); return false;}function evaluate_final_score(){\n         element = document.getElementById('checkdown_final_score');\n         if(element === null){return false;} else {var element, text, res1;res1 = document.getElementById('result_Q5_1').innerText == 'That’s right. Without quotation marks, a string of characters is interpreted by R as the name of an object or function.';text = res1;element.innerHTML = text;\n         return false;\n         }}</script>\n```\n\n:::\n:::\n\n:::\n::: {.callout-tip collapse=\"false\"}\n#### Your turn! {.unnumbered}\n\n[**Q5.2**]{style=\"color:green;\"} Try entering `13^2` in the Console. What does the `^` (caret) operator do?\n\n\n::: {.cell}\n::: {.cell-output-display}\n\n```{=html}\n<form name=\"form_Q5_2\" onsubmit=\"return validate_form_Q5_2()\" method=\"post\">\n<label>\n<input type=\"radio\" name=\"answer_Q5_2\" id=\"answer_Q5_2_1\" value=\"The ^ operator calculates the modulus of a number, here of 13 with 2 as the base.\"/>\nThe ^ operator calculates the modulus of a number, here of 13 with 2 as the base.\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q5_2\" id=\"answer_Q5_2_2\" value=\"The ^ operator creates a vector, here with 13 occurrences of the integer 2.\"/>\nThe ^ operator creates a vector, here with 13 occurrences of the integer 2.\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q5_2\" id=\"answer_Q5_2_3\" value=\"The ^ operator performs an exponentiation operation, here 13 to the power of 2.\"/>\nThe ^ operator performs an exponentiation operation, here 13 to the power of 2.\n</label>\n<br/>\n<input type=\"submit\" value=\"Check answer\"/>\n<div id=\"result_Q5_2\"></div>\n</form>\n<script>function validate_form_Q5_2() {var x, text; var x = document.forms['form_Q5_2']['answer_Q5_2'].value;if (x == 'The ^ operator performs an exponentiation operation, here 13 to the power of 2.'){text = 'That’s right. Raising 13 to the power of 2 gives us the square of 13. Which is why the output is the same as for 13*13!';} else {text = 'No. Compare the output of the operation 13^2 with 13*13. What do you notice?';} document.getElementById('result_Q5_2').innerHTML = text; evaluate_final_score(); return false;}function evaluate_final_score(){\n         element = document.getElementById('checkdown_final_score');\n         if(element === null){return false;} else {var element, text, res1, res2;res1 = document.getElementById('result_Q5_1').innerText == 'That’s right. Without quotation marks, a string of characters is interpreted by R as the name of an object or function.'; res2 = document.getElementById('result_Q5_2').innerText == 'That’s right. Raising 13 to the power of 2 gives us the square of 13. Which is why the output is the same as for 13*13!';text = res1 + res2;element.innerHTML = text;\n         return false;\n         }}</script>\n```\n\n:::\n:::\n\n\n[**Q5.3**]{style=\"color:green;\"} Compare `13*13` with `13 * 13`. What is the difference in the output?\n\n\n::: {.cell}\n::: {.cell-output-display}\n\n```{=html}\n<form name=\"form_Q5_3\" onsubmit=\"return validate_form_Q5_3()\" method=\"post\">\n<label>\n<input type=\"radio\" name=\"answer_Q5_3\" id=\"answer_Q5_3_1\" value=\"There is no difference.\"/>\nThere is no difference.\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q5_3\" id=\"answer_Q5_3_2\" value=\"Adding a space generates an error.\"/>\nAdding a space generates an error.\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q5_3\" id=\"answer_Q5_3_3\" value=\"It is impossible to add a space in the R Console.\"/>\nIt is impossible to add a space in the R Console.\n</label>\n<br/>\n<input type=\"submit\" value=\"Check answer\"/>\n<div id=\"result_Q5_3\"></div>\n</form>\n<script>function validate_form_Q5_3() {var x, text; var x = document.forms['form_Q5_3']['answer_Q5_3'].value;if (x == 'There is no difference.'){text = 'That’s right. Adding spaces within mathematical operations makes no difference in R. However, it’s good practice to keep things consistent.';} else {text = 'No. Have you tried?';} document.getElementById('result_Q5_3').innerHTML = text; evaluate_final_score(); return false;}function evaluate_final_score(){\n         element = document.getElementById('checkdown_final_score');\n         if(element === null){return false;} else {var element, text, res1, res2, res3;res1 = document.getElementById('result_Q5_1').innerText == 'That’s right. Without quotation marks, a string of characters is interpreted by R as the name of an object or function.'; res2 = document.getElementById('result_Q5_2').innerText == 'That’s right. Raising 13 to the power of 2 gives us the square of 13. Which is why the output is the same as for 13*13!'; res3 = document.getElementById('result_Q5_3').innerText == 'That’s right. Adding spaces within mathematical operations makes no difference in R. However, it’s good practice to keep things consistent.';text = res1 + res2 + res3;element.innerHTML = text;\n         return false;\n         }}</script>\n```\n\n:::\n:::\n\n:::\n::: {.callout-tip collapse=\"false\"}\n#### Your turn! {.unnumbered}\n\n[**Q5.4**]{style=\"color:green;\"} Which of these object names are *not* allowed in `R`? Try to create an object with each of these names and see if you get an error message or not.\n\n\n::: {.cell}\n::: {.cell-output-display}\n\n```{=html}\n<form name=\"form_Q5_4\" onsubmit=\"return validate_form_Q5_4()\" method=\"post\">\n<label>\n<input type=\"checkbox\" id=\"answer_Q5_4_1\" value=\"1TopWord\"/>\n1TopWord\n</label>\n<br/>\n<label>\n<input type=\"checkbox\" id=\"answer_Q5_4_2\" value=\"Top1Word\"/>\nTop1Word\n</label>\n<br/>\n<label>\n<input type=\"checkbox\" id=\"answer_Q5_4_3\" value=\"top word\"/>\ntop word\n</label>\n<br/>\n<label>\n<input type=\"checkbox\" id=\"answer_Q5_4_4\" value=\"my-favourite-word\"/>\nmy-favourite-word\n</label>\n<br/>\n<label>\n<input type=\"checkbox\" id=\"answer_Q5_4_5\" value=\"BestWordEver!\"/>\nBestWordEver!\n</label>\n<br/>\n<label>\n<input type=\"checkbox\" id=\"answer_Q5_4_6\" value=\"Agnès.Favourite.Word\"/>\nAgnès.Favourite.Word\n</label>\n<br/>\n<input type=\"submit\" value=\"Check answer\"/>\n<div id=\"result_Q5_4\"></div>\n</form>\n<script>function validate_form_Q5_4() {var text; var x1 = document.getElementById('answer_Q5_4_1'); var x2 = document.getElementById('answer_Q5_4_2'); var x3 = document.getElementById('answer_Q5_4_3'); var x4 = document.getElementById('answer_Q5_4_4'); var x5 = document.getElementById('answer_Q5_4_5'); var x6 = document.getElementById('answer_Q5_4_6'); if (x1.checked == true&x2.checked == false&x3.checked == true&x4.checked == true&x5.checked == true&x6.checked == false){text = 'That’s right! 🎉';} else {text = 'Not quite. Try again!';} document.getElementById('result_Q5_4').innerHTML = text; evaluate_final_score(); return false;}function evaluate_final_score(){\n         element = document.getElementById('checkdown_final_score');\n         if(element === null){return false;} else {var element, text, res1, res2, res3, res4;res1 = document.getElementById('result_Q5_1').innerText == 'That’s right. Without quotation marks, a string of characters is interpreted by R as the name of an object or function.'; res2 = document.getElementById('result_Q5_2').innerText == 'That’s right. Raising 13 to the power of 2 gives us the square of 13. Which is why the output is the same as for 13*13!'; res3 = document.getElementById('result_Q5_3').innerText == 'That’s right. Adding spaces within mathematical operations makes no difference in R. However, it’s good practice to keep things consistent.'; res4 = document.getElementById('result_Q5_4').innerText == 'That’s right! 🎉';text = res1 + res2 + res3 + res4;element.innerHTML = text;\n         return false;\n         }}</script>\n```\n\n:::\n\n::: {.cell-output-display}\n\n```{=html}\n<div id=\"hint_99214\" onclick=\"return show_hint_99214()\">🐭 Click on the mouse for a hint.</div>\n<div id=\"result_99214\" onclick=\"return show_hint_99214()\"></div>\n<script>function show_hint_99214(){var x = document.getElementById('result_99214').innerHTML; if(!x){document.getElementById('result_99214').innerHTML = 'Four of these object names are problematic and will return errors.';} else {document.getElementById('result_99214').innerHTML = '';}}</script>\n```\n\n:::\n:::\n\n:::\n::: {.callout-tip collapse=\"false\"}\n#### Your turn! {.unnumbered}\n\n[**Q5.5**]{style=\"color:green;\"} What is the relational operator that checks whether a value is \"more than or equal to\" another value?\n\n\n::: {.cell}\n::: {.cell-output-display}\n\n```{=html}\n<form name=\"form_Q5_5\" onsubmit=\"return validate_form_Q5_5()\" method=\"post\">\n<input type=\"text\" placeholder=\"\" name=\"answer_Q5_5\"/>\n<input type=\"submit\" value=\"check\"/>\n<div id=\"result_Q5_5\"></div>\n</form>\n<script>function validate_form_Q5_5() {var x, text; var x = document.forms['form_Q5_5']['answer_Q5_5'].value;if (x == '>='){text = 'That’s right!';} else {text = 'No. Experiment with the lines of code above to find the correct operator.';} document.getElementById('result_Q5_5').innerHTML = text; evaluate_final_score(); return false;}function evaluate_final_score(){\n         element = document.getElementById('checkdown_final_score');\n         if(element === null){return false;} else {var element, text, res1, res2, res3, res4, res5;res1 = document.getElementById('result_Q5_1').innerText == 'That’s right. Without quotation marks, a string of characters is interpreted by R as the name of an object or function.'; res2 = document.getElementById('result_Q5_2').innerText == 'That’s right. Raising 13 to the power of 2 gives us the square of 13. Which is why the output is the same as for 13*13!'; res3 = document.getElementById('result_Q5_3').innerText == 'That’s right. Adding spaces within mathematical operations makes no difference in R. However, it’s good practice to keep things consistent.'; res4 = document.getElementById('result_Q5_4').innerText == 'That’s right! 🎉'; res5 = document.getElementById('result_Q5_5').innerText == 'That’s right!';text = res1 + res2 + res3 + res4 + res5;element.innerHTML = text;\n         return false;\n         }}</script>\n```\n\n:::\n\n::: {.cell-output-display}\n\n```{=html}\n<div id=\"hint_48171\" onclick=\"return show_hint_48171()\">🐭 Click on the mouse for a hint.</div>\n<div id=\"result_48171\" onclick=\"return show_hint_48171()\"></div>\n<script>function show_hint_48171(){var x = document.getElementById('result_48171').innerHTML; if(!x){document.getElementById('result_48171').innerHTML = 'This operator is a combination of two symbols.';} else {document.getElementById('result_48171').innerHTML = '';}}</script>\n```\n\n:::\n:::\n\n\n[**Q5.6**]{style=\"color:green;\"} What is the relational operator that checks whether a value \"is not equal to\" another value?\n\n\n::: {.cell}\n::: {.cell-output-display}\n\n```{=html}\n<form name=\"form_Q5_6\" onsubmit=\"return validate_form_Q5_6()\" method=\"post\">\n<input type=\"text\" placeholder=\"\" name=\"answer_Q5_6\"/>\n<input type=\"submit\" value=\"check\"/>\n<div id=\"result_Q5_6\"></div>\n</form>\n<script>function validate_form_Q5_6() {var x, text; var x = document.forms['form_Q5_6']['answer_Q5_6'].value;if (x == '!='){text = 'That’s right!';} else {text = 'No. Experiment with the lines of code above to find the correct operator.';} document.getElementById('result_Q5_6').innerHTML = text; evaluate_final_score(); return false;}function evaluate_final_score(){\n         element = document.getElementById('checkdown_final_score');\n         if(element === null){return false;} else {var element, text, res1, res2, res3, res4, res5, res6;res1 = document.getElementById('result_Q5_1').innerText == 'That’s right. Without quotation marks, a string of characters is interpreted by R as the name of an object or function.'; res2 = document.getElementById('result_Q5_2').innerText == 'That’s right. Raising 13 to the power of 2 gives us the square of 13. Which is why the output is the same as for 13*13!'; res3 = document.getElementById('result_Q5_3').innerText == 'That’s right. Adding spaces within mathematical operations makes no difference in R. However, it’s good practice to keep things consistent.'; res4 = document.getElementById('result_Q5_4').innerText == 'That’s right! 🎉'; res5 = document.getElementById('result_Q5_5').innerText == 'That’s right!'; res6 = document.getElementById('result_Q5_6').innerText == 'That’s right!';text = res1 + res2 + res3 + res4 + res5 + res6;element.innerHTML = text;\n         return false;\n         }}</script>\n```\n\n:::\n\n::: {.cell-output-display}\n\n```{=html}\n<div id=\"hint_28408\" onclick=\"return show_hint_28408()\">🐭 Click on the mouse for a hint.</div>\n<div id=\"result_28408\" onclick=\"return show_hint_28408()\"></div>\n<script>function show_hint_28408(){var x = document.getElementById('result_28408').innerHTML; if(!x){document.getElementById('result_28408').innerHTML = 'This operator is a combination of two symbols.';} else {document.getElementById('result_28408').innerHTML = '';}}</script>\n```\n\n:::\n:::\n\n:::\n::: {.callout-tip collapse=\"false\"}\n#### Your turn! {.unnumbered}\n\nAbove, we created the following `R` character string object:\n\n\n::: {.cell}\n\n```{.r .cell-code}\nNew.French.Word <- \"écogeste\"\n```\n:::\n\n\n[**Q5.7**]{style=\"color:green;\"} Why does this line of code return `FALSE` even though `New.French.Word` was assigned the character string \"écogeste\"?\n\n\n::: {.cell}\n\n```{.r .cell-code}\nNew.French.Word == \"ecogeste\"\n```\n:::\n\n\n\n::: {.cell}\n::: {.cell-output-display}\n\n```{=html}\n<form name=\"form_Q5_7\" onsubmit=\"return validate_form_Q5_7()\" method=\"post\">\n<label>\n<input type=\"radio\" name=\"answer_Q5_7\" id=\"answer_Q5_7_1\" value=\"Because &quot;écogeste&quot; and &quot;ecogeste&quot; are two different strings in R.\"/>\nBecause \"écogeste\" and \"ecogeste\" are two different strings in R.\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q5_7\" id=\"answer_Q5_7_2\" value=\"Because R automatically removed the accent as object names must be in English.\"/>\nBecause R automatically removed the accent as object names must be in English.\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q5_7\" id=\"answer_Q5_7_3\" value=\"Because == cannot be used to compare character strings in French.\"/>\nBecause == cannot be used to compare character strings in French.\n</label>\n<br/>\n<input type=\"submit\" value=\"Check answer\"/>\n<div id=\"result_Q5_7\"></div>\n</form>\n<script>function validate_form_Q5_7() {var x, text; var x = document.forms['form_Q5_7']['answer_Q5_7'].value;if (x == 'Because \"écogeste\" and \"ecogeste\" are two different strings in R.'){text = 'Correct! The string saved as New.French.Word is “écogeste” not “ecogeste”.';} else {text = 'No, that’s not the reason.';} document.getElementById('result_Q5_7').innerHTML = text; evaluate_final_score(); return false;}function evaluate_final_score(){\n         element = document.getElementById('checkdown_final_score');\n         if(element === null){return false;} else {var element, text, res1, res2, res3, res4, res5, res6, res7;res1 = document.getElementById('result_Q5_1').innerText == 'That’s right. Without quotation marks, a string of characters is interpreted by R as the name of an object or function.'; res2 = document.getElementById('result_Q5_2').innerText == 'That’s right. Raising 13 to the power of 2 gives us the square of 13. Which is why the output is the same as for 13*13!'; res3 = document.getElementById('result_Q5_3').innerText == 'That’s right. Adding spaces within mathematical operations makes no difference in R. However, it’s good practice to keep things consistent.'; res4 = document.getElementById('result_Q5_4').innerText == 'That’s right! 🎉'; res5 = document.getElementById('result_Q5_5').innerText == 'That’s right!'; res6 = document.getElementById('result_Q5_6').innerText == 'That’s right!'; res7 = document.getElementById('result_Q5_7').innerText == 'Correct! The string saved as New.French.Word is “écogeste” not “ecogeste”.';text = res1 + res2 + res3 + res4 + res5 + res6 + res7;element.innerHTML = text;\n         return false;\n         }}</script>\n```\n\n:::\n:::\n\n\n[**Q5.8**]{style=\"color:green;\"} Why does this line of code return `FALSE`?\n\n\n::: {.cell}\n\n```{.r .cell-code}\nNew.French.Word == \" écogeste\"\n```\n:::\n\n\n\n::: {.cell}\n::: {.cell-output-display}\n\n```{=html}\n<form name=\"form_Q5_8\" onsubmit=\"return validate_form_Q5_8()\" method=\"post\">\n<label>\n<input type=\"radio\" name=\"answer_Q5_8\" id=\"answer_Q5_8_1\" value=\"Because string objects cannot include any special characters. This includes spaces.\"/>\nBecause string objects cannot include any special characters. This includes spaces.\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q5_8\" id=\"answer_Q5_8_2\" value=\"Because this string includes an additional space character.\"/>\nBecause this string includes an additional space character.\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q5_8\" id=\"answer_Q5_8_3\" value=\"Because R is case-sensitive.\"/>\nBecause R is case-sensitive.\n</label>\n<br/>\n<input type=\"submit\" value=\"Check answer\"/>\n<div id=\"result_Q5_8\"></div>\n</form>\n<script>function validate_form_Q5_8() {var x, text; var x = document.forms['form_Q5_8']['answer_Q5_8'].value;if (x == 'Because this string includes an additional space character.'){text = 'Correct! The extra space means that this string does not match the string saved as New.French.Word in the environment.';} else {text = 'No, that’s not the reason.';} document.getElementById('result_Q5_8').innerHTML = text; evaluate_final_score(); return false;}function evaluate_final_score(){\n         element = document.getElementById('checkdown_final_score');\n         if(element === null){return false;} else {var element, text, res1, res2, res3, res4, res5, res6, res7, res8;res1 = document.getElementById('result_Q5_1').innerText == 'That’s right. Without quotation marks, a string of characters is interpreted by R as the name of an object or function.'; res2 = document.getElementById('result_Q5_2').innerText == 'That’s right. Raising 13 to the power of 2 gives us the square of 13. Which is why the output is the same as for 13*13!'; res3 = document.getElementById('result_Q5_3').innerText == 'That’s right. Adding spaces within mathematical operations makes no difference in R. However, it’s good practice to keep things consistent.'; res4 = document.getElementById('result_Q5_4').innerText == 'That’s right! 🎉'; res5 = document.getElementById('result_Q5_5').innerText == 'That’s right!'; res6 = document.getElementById('result_Q5_6').innerText == 'That’s right!'; res7 = document.getElementById('result_Q5_7').innerText == 'Correct! The string saved as New.French.Word is “écogeste” not “ecogeste”.'; res8 = document.getElementById('result_Q5_8').innerText == 'Correct! The extra space means that this string does not match the string saved as New.French.Word in the environment.';text = res1 + res2 + res3 + res4 + res5 + res6 + res7 + res8;element.innerHTML = text;\n         return false;\n         }}</script>\n```\n\n:::\n:::\n\n\n[**Q5.9**]{style=\"color:green;\"} Why does this line of code return `FALSE`?\n\n\n::: {.cell}\n\n```{.r .cell-code}\nNew.French.Word == \"Écogeste\"\n```\n:::\n\n\n\n::: {.cell}\n::: {.cell-output-display}\n\n```{=html}\n<form name=\"form_Q5_9\" onsubmit=\"return validate_form_Q5_9()\" method=\"post\">\n<label>\n<input type=\"radio\" name=\"answer_Q5_9\" id=\"answer_Q5_9_1\" value=\"Because this word is not in the dictionary of the Académie Française.\"/>\nBecause this word is not in the dictionary of the Académie Française.\n</label>\n<br/>\n<label>\n<input type=\"radio\" name=\"answer_Q5_9\" id=\"answer_Q5_9_2\" value=\"Because R 